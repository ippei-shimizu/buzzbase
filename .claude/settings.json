{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git status)",
      "Bash(git branch *)",
      "Bash(git add *)",
      "Bash(git add * && git commit *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git branch --show-current && *)",
      "Bash(git log origin/main..HEAD *)",
      "Bash(git remote -v)",
      "Bash(gh pr view *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr list *)",
      "Bash(gh pr create *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(ls -la *)",
      "Bash(ls * 2>/dev/null || echo *)",
      "Bash(find *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(grep *)",
      "Bash(cd /Users/shimizuippei/projects/dev/buzzbase && *)",
      "Bash(cd /Users/shimizuippei/projects/dev/buzzbase/back && *)",
      "Bash(cd /Users/shimizuippei/projects/dev/buzzbase/front && *)",
      "Bash(cd /Users/shimizuippei/projects/dev/buzzbase/mobile && *)",
      "Bash(ISSUE_NODE_ID=$(gh issue view * --repo ippei-shimizu/buzzbase *) && gh api graphql *)",
      "Bash(gh api graphql *)",
      "Bash(gh issue view *)",
      "Bash(gh issue list *)",
      "Bash(ls -la * 2>/dev/null)",
      "mcp__serena__*"
    ],
    "deny": [
      "Bash(curl *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./**/credentials.yml.enc)",
      "Read(./**/master.key)",
      "Bash(rm -rf *)",
      "Bash(git merge *)"
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  }
}
